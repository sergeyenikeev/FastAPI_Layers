APP_NAME=workflow-platform
APP_ENV=dev
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8080
DATABASE_URL=postgresql+asyncpg://workflow_user:replace-me@postgres:5432/workflow_db
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=["kafka:9092"]
KAFKA_CLIENT_ID=workflow-platform
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
API_KEYS=["replace-with-api-key"]
JWT_SECRET=replace-with-strong-secret
JWT_ALGORITHM=HS256
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_ENABLED=true
DEFAULT_ALERT_WEBHOOK=
DEFAULT_ALERT_EMAIL=team@example.com
MODEL_TIMEOUT_SECONDS=30
COST_SPIKE_ZSCORE=2.5
LATENCY_SPIKE_ZSCORE=2.0
ALERT_COOLDOWN_SECONDS=300
